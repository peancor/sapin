# ======================================================================
# SAPIN - Production environment example (Docker)
# Copy to .env.production and replace example values before deploy
# ======================================================================

# REQUIRED (64 hex chars)
SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Public URL used by SvelteKit CSRF checks (IMPORTANT)
ORIGIN=https://tu-dominio.com

# Host port mapping
SAPIN_PORT=3000

# Optional feature toggles
MODERATE_PROMPTS=false
ENABLE_TELEGRAM_NOTIFICATIONS=false

# Optional anti-bot (Turnstile)
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional vector DB / RAG
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
EMBEDDINGS_OPENROUTER_API_KEY=

# Optional OpenAI moderation
OPENAI_MODERATION_API_KEY=

# Optional image name override for production compose
# SAPIN_IMAGE=peancor/sapin:latest
