		"@tiptap/core": "^3.17.0",
		"@tiptap/extension-highlight": "^3.17.0",
		"@tiptap/extension-image": "^3.22.3",
		"@tiptap/extension-link": "^3.17.0",
		"@tiptap/extension-placeholder": "^3.17.0",
		"@tiptap/extension-text-align": "^3.17.0",
		"@tiptap/extension-typography": "^3.17.0",
		"@tiptap/extension-underline": "^3.17.0",
		"@tiptap/markdown": "^3.17.0",
		"@tiptap/pm": "^3.17.0",
		"@tiptap/starter-kit": "^3.17.0",
		"@types/bcrypt": "^6.0.0",
		"@types/file-saver": "^2.0.7",
		"@types/node-cron": "^3.0.11",
		"@types/nodemailer": "^7.0.5",
		"@types/pdf-parse": "^1.1.5",
		"@xyflow/svelte": "^1.5.2",
		"ai": "^6.0.49",
		"bcrypt": "^6.0.0",
		"better-sqlite3": "^12.6.2",
		"csv-parse": "^6.1.0",
		"diacritics": "^1.3.0",
		"docx": "^9.5.1",
		"drizzle-orm": "^0.45.1",
		"echarts": "^6.0.0",
		"express": "^5.2.1",
		"file-saver": "^2.0.5",
		"handlebars": "^4.7.8",
		"jsxgraph": "^1.12.2",
		"katex": "^0.16.27",
		"lucide-svelte": "^0.563.0",
		"mammoth": "^1.11.0",
		"marked": "^17.0.1",
		"marked-katex-extension": "^5.1.6",
		"node-cron": "^4.2.1",
		"node-tikzjax": "^1.0.5",
		"nodemailer": "^7.0.12",
