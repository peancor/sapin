{
	"name": "sapin",
	"private": true,
	"version": "0.99.1",
	"type": "module",
	"engines": {
		"node": ">=22.14.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"postbuild": "cpy \"./myserver.js\" \"build/\" --verbose",
		"docker:build": "docker compose build",
		"docker:up": "docker compose up -d --build",
		"docker:down": "docker compose down",
		"docker:restart": "docker compose down && docker compose up -d",
		"docker:clean": "docker compose down -v --remove-orphans",
		"docker:logs": "docker compose logs -f sapin",
		"docker:ps": "docker compose ps",
		"docker:secret": "node -e \"console.log(require('node:crypto').randomBytes(32).toString('hex'))\"",
		"docker:prod:up": "docker compose -f docker-compose.prod.yml --env-file .env.production up -d",
		"docker:prod:down": "docker compose -f docker-compose.prod.yml --env-file .env.production down",
		"docker:prod:logs": "docker compose -f docker-compose.prod.yml --env-file .env.production logs -f sapin",
		"docker:prod:ps": "docker compose -f docker-compose.prod.yml --env-file .env.production ps",
		"docker:prod:pull": "docker compose -f docker-compose.prod.yml --env-file .env.production pull",
		"docker:prod:update": "docker compose -f docker-compose.prod.yml --env-file .env.production pull && docker compose -f docker-compose.prod.yml --env-file .env.production up -d",
		"docker:qdrant:debug:up": "docker compose -f docker-compose.yml -f docker-compose.qdrant-debug.yml up -d",
		"docker:qdrant:debug:down": "docker compose -f docker-compose.yml -f docker-compose.qdrant-debug.yml down",
		"preview": "vite preview",
		"test": "node --import ./scripts/node-test-register.mjs --test \"src/**/*.test.ts\"",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"db:push": "drizzle-kit push",
		"db:migrate": "drizzle-kit migrate",
		"db:generate": "drizzle-kit generate",
		"db:studio": "drizzle-kit studio",
		"db:backfill-agent-ui-components": "npx tsx scripts/backfill-agent-ui-components.ts",
		"machine-translate": "inlang machine translate --project project.inlang"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.1",
		"@eslint/js": "^9.39.2",
		"@inlang/cli": "^3.0.0",
		"@inlang/paraglide-js": "^2.9.1",
		"@sveltejs/adapter-node": "^5.5.2",
		"@sveltejs/kit": "^2.50.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/better-sqlite3": "^7.6.13",
		"@types/diacritics": "^1.3.3",
		"cpy-cli": "^6.0.0",
		"dotenv": "^17.2.3",
		"drizzle-kit": "^0.31.8",
		"drizzle-zod": "^0.8.3",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"flowbite": "^4.0.1",
		"flowbite-svelte": "^1.31.0",
		"flowbite-svelte-icons": "^3.1.0",
		"globals": "^17.1.0",
		"mdsvex": "^0.12.6",
		"pino-pretty": "^13.1.3",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.48.0",
		"svelte-check": "^4.3.5",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.53.1",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vite-plugin-static-copy": "^3.1.6"
	},
	"dependencies": {
		"@ai-sdk/openai": "^3.0.18",
		"@ai-sdk/openai-compatible": "^2.0.18",
		"@ai-sdk/svelte": "^4.0.49",
		"@microsoft/fetch-event-source": "^2.0.1",
		"@node-rs/argon2": "^2.0.2",
		"@openrouter/ai-sdk-provider": "^2.0.0",
		"@oslojs/crypto": "^1.0.1",
		"@oslojs/encoding": "^1.1.0",
		"@qdrant/js-client-rest": "^1.16.2",
		"@rod2ik/tikzjax": "^1.0.0-beta32",
