# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
DATABASE_URL=local.db

# URL pública de la app (se usa para enlaces absolutos y HTTP-Referer en OpenRouter)
ORIGIN=http://localhost:5173

# ==============================================================================
# LTI ADVANTAGE TOOL CONFIGURATION
# ==============================================================================
LTI_ENABLED=false
LTI_TRUSTED_ORIGINS=https://moodle.example.edu
LTI_TOOL_NAME=Sapin
LTI_COOKIE_SAMESITE_NONE=false
LTI_COOKIE_SECURE=true

# ==============================================================================
# CONTENT MODERATION
# ==============================================================================
MODERATE_PROMPTS=false

# ==============================================================================
# CLOUDFLARE TURNSTILE (Anti-bot verification)
# ==============================================================================
# Get your keys at https://dash.cloudflare.com/turnstile
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ==============================================================================
# TELEGRAM NOTIFICATIONS
# ==============================================================================
ENABLE_TELEGRAM_NOTIFICATIONS=false
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ==============================================================================
# QDRANT VECTOR DATABASE
# ==============================================================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_api_key_here  # Optional: uncomment if using authentication
EMBEDDINGS_OPENROUTER_API_KEY=your_openrouter_api_key_here  # required for OpenRouter embeddings

# ==============================================================================
# FILE STORAGE SYSTEM
# ==============================================================================
FILES_STORAGE_PATH=uploads/files
FILES_TEMP_PATH=uploads/temp
FILES_DELETED_PATH=uploads/deleted

# ==============================================================================
# OPENAI MODERATION API KEY
# ==============================================================================
OPENAI_MODERATION_API_KEY=''
